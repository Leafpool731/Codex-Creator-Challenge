{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shade-season",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "build": {
    "command": "npm run worker:build",
    "watch_dir": [
      "app",
      "components",
      "data",
      "lib",
      "next.config.mjs",
      "package.json",
      "tailwind.config.ts",
      "tsconfig.json"
    ]
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
